{
  "name": "@quickrent/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "dev:win": "set EXPO_NO_TYPESCRIPT_SETUP=true&& expo start --web --clear --port 8085",
    "dev:web": "set EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1 && expo start --web --clear --port 8085",
    "clean:web": "rimraf -rf .expo node_modules/.cache && expo start --web --clear --port 8085",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run lint"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo/metro-runtime": "~4.0.1",
    "@hookform/resolvers": "^3.9.1",
    "@quickrent/design-system": "workspace:*",
    "@react-navigation/native": "^7.0.8",
    "@react-navigation/native-stack": "^7.1.15",
    "@tanstack/react-query": "^5.62.16",
    "expo": "^52.0.15",
    "expo-localization": "^16.0.0",
    "expo-status-bar": "^2.0.1",
    "i18next": "^24.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.53.2",
    "react-i18next": "^15.1.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-maps": "1.18.0",
    "react-native-safe-area-context": "^4.12.0",
    "react-native-screens": "^4.1.0",
    "react-native-web": "~0.19.13",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@react-native-community/cli": "15.1.3",
    "@react-native-community/cli-platform-android": "15.1.3",
    "@react-native-community/cli-platform-ios": "15.1.3"
  }
}