{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true,
    "paths": {
      "@quickrent/design-system": [
        "./src/types/quickrent-design-system.d.ts"
      ]
    },
    "types": [
      "react",
      "react-dom"
    ]
  },
  "include": [
    "App.tsx",
    "index.js",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "../../node_modules"
  ]
}
