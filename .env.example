# Global platform
NODE_ENV=development

# Database
DATABASE_URL=postgresql://quickrent:quickrent@localhost:5432/quickrent
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Security / auth flows
OTP_PROVIDER=mock
OTP_TTL_SECONDS=300
PASSWORD_RESET_TTL_MINUTES=30
ACCOUNT_VERIFICATION_TTL_HOURS=24

# API
API_PORT=4000
API_PREFIX=api/v1
APP_BASE_URL=http://localhost:3000
WS_PORT=4001

# Maps / routing
GOOGLE_MAPS_API_KEY=change-me-google-maps-key
GOOGLE_MAPS_REGION=QA

# Storage
STORAGE_PROVIDER=s3
STORAGE_BUCKET=quickrent-platform
STORAGE_REGION=eu-west-1

# Payments
PAYMENT_PROVIDER=stripe
PAYMENT_WEBHOOK_SECRET=change-me-webhook

# Next.js public config
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=change-me-google-maps-key

# Mobile public config
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=change-me-google-maps-key
EXPO_PUBLIC_WS_URL=ws://localhost:4001
