{
  "name": "quickrent-platform",
  "private": true,
  "version": "1.0.0",
  "description": "QuickRent global rental super app monorepo",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @quickrent/api dev",
    "dev:mobile": "pnpm --filter @quickrent/mobile dev",
    "dev:admin": "pnpm --filter @quickrent/admin-web dev",
    "dev:landlord": "pnpm --filter @quickrent/landlord-web dev",
    "dev:provider": "pnpm --filter @quickrent/provider-web dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @quickrent/api prisma:generate",
    "db:migrate": "pnpm --filter @quickrent/api prisma:migrate",
    "db:seed": "pnpm --filter @quickrent/api prisma:seed"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "expo": "^52.0.15"
  }
}