{
  "name": "@quickrent/config",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').copyFileSync('dist/index.js','dist/index.cjs')\""
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
